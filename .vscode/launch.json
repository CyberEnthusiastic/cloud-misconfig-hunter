{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Hunt: bundled samples/",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/hunter.py",
      "args": ["samples/"],
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Hunt: current file only",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/hunter.py",
      "args": ["${file}"],
      "console": "integratedTerminal"
    },
    {
      "name": "Hunt: prompt for path",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/hunter.py",
      "args": ["${input:targetPath}"],
      "console": "integratedTerminal"
    }
  ],
  "inputs": [
    {
      "id": "targetPath",
      "type": "promptString",
      "description": "Path to the Terraform/JSON file or directory to scan",
      "default": "samples/"
    }
  ]
}
